        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="[Label] Set discovery window label by elapsed time" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script"><![CDATA[if (props.get('rsat.discovery.start.ms') == null) {
    props.put('rsat.discovery.start.ms', System.currentTimeMillis().toString())
}
long startMs = props.get('rsat.discovery.start.ms') as long
long elapsedSec = ((System.currentTimeMillis() - startMs) / 1000L) as long

def ranges = [
  [0L, 60L, 'DISCARD_WARMUP_0000_TO_0600_RPS'],
  [60L, 70L, 'DISCARD_0600_RPS_STABILIZE_10S'],
  [70L, 130L, 'MEASURE_0600_RPS_MIXED_1000PLUS_STEADY_60S'],
  [130L, 140L, 'DISCARD_0600_RPS_END_GUARD_10S'],
  [140L, 160L, 'DISCARD_RAMP_0600_TO_0800_RPS'],
  [160L, 170L, 'DISCARD_0800_RPS_STABILIZE_10S'],
  [170L, 230L, 'MEASURE_0800_RPS_MIXED_1000PLUS_STEADY_60S'],
  [230L, 240L, 'DISCARD_0800_RPS_END_GUARD_10S'],
  [240L, 260L, 'DISCARD_RAMP_0800_TO_1000_RPS'],
  [260L, 270L, 'DISCARD_1000_RPS_STABILIZE_10S'],
  [270L, 330L, 'MEASURE_1000_RPS_MIXED_1000PLUS_STEADY_60S'],
  [330L, 340L, 'DISCARD_1000_RPS_END_GUARD_10S'],
  [340L, 360L, 'DISCARD_RAMP_1000_TO_1100_RPS'],
  [360L, 370L, 'DISCARD_1100_RPS_STABILIZE_10S'],
  [370L, 430L, 'MEASURE_1100_RPS_MIXED_1000PLUS_STEADY_60S'],
  [430L, 440L, 'DISCARD_1100_RPS_END_GUARD_10S'],
  [440L, 460L, 'DISCARD_RAMP_1100_TO_1200_RPS'],
  [460L, 470L, 'DISCARD_1200_RPS_STABILIZE_10S'],
  [470L, 530L, 'MEASURE_1200_RPS_MIXED_1000PLUS_STEADY_60S'],
  [530L, 540L, 'DISCARD_1200_RPS_END_GUARD_10S'],
  [540L, 560L, 'DISCARD_RAMP_1200_TO_1300_RPS'],
  [560L, 570L, 'DISCARD_1300_RPS_STABILIZE_10S'],
  [570L, 630L, 'MEASURE_1300_RPS_MIXED_1000PLUS_STEADY_60S'],
  [630L, 640L, 'DISCARD_1300_RPS_END_GUARD_10S'],
  [640L, 660L, 'DISCARD_RAMP_1300_TO_1400_RPS'],
  [660L, 670L, 'DISCARD_1400_RPS_STABILIZE_10S'],
  [670L, 730L, 'MEASURE_1400_RPS_MIXED_1000PLUS_STEADY_60S'],
  [730L, 740L, 'DISCARD_1400_RPS_END_GUARD_10S'],
  [740L, 760L, 'DISCARD_RAMP_1400_TO_1500_RPS'],
  [760L, 770L, 'DISCARD_1500_RPS_STABILIZE_10S'],
  [770L, 830L, 'MEASURE_1500_RPS_MIXED_1000PLUS_STEADY_60S'],
  [830L, 840L, 'DISCARD_1500_RPS_END_GUARD_10S'],
  [840L, 860L, 'DISCARD_RAMP_1500_TO_1600_RPS'],
  [860L, 870L, 'DISCARD_1600_RPS_STABILIZE_10S'],
  [870L, 930L, 'MEASURE_1600_RPS_MIXED_1000PLUS_STEADY_60S'],
  [930L, 940L, 'DISCARD_1600_RPS_END_GUARD_10S'],
  [940L, 980L, 'DISCARD_RAMPDOWN_1600_TO_0000_RPS']
]
String label = 'DISCARD_AFTER_SCHEDULE'
for (r in ranges) {
    if (elapsedSec >= r[0] && elapsedSec < r[1]) {
        label = r[2]
        break
    }
}
vars.put('RSAT_DISCOVERY_LABEL', label)
vars.put('RSAT_DISCOVERY_ELAPSED_SEC', elapsedSec.toString())
]]></stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>

      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="[Main] R_sat Discovery - Mixed 1000plus 600 to 1600 RPS">
        <stringProp name="TestPlan.comments">R_sat discovery for 1000plus mixed workload. Analyze only MEASURE_xxxx_RPS_MIXED_1000PLUS_STEADY_60S labels. Ignore all DISCARD labels.</stringProp>
        <intProp name="ThreadGroup.num_threads">2500</intProp>
        <intProp name="ThreadGroup.ramp_time">30</intProp>
        <longProp name="ThreadGroup.duration">1050</longProp>
        <longProp name="ThreadGroup.delay">0</longProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>

  <kg.apc.jmeter.timers.VariableThroughputTimer guiclass="kg.apc.jmeter.timers.VariableThroughputTimerGui" testclass="kg.apc.jmeter.timers.VariableThroughputTimer" testname="jp@gc - Throughput Shaping Timer | R_sat confirm 1000 to 1250 RPS" enabled="true">
  <collectionProp name="load_profile">
          <collectionProp name="step_0">
            <stringProp name="start_rps_0">0</stringProp>
            <stringProp name="end_rps_0">1000</stringProp>
            <stringProp name="duration_sec_0">60</stringProp>

  <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="[Label] Set benchmark phase label by elapsed time" enabled="true">
  <stringProp name="cacheKey">true</stringProp><stringProp name="filename"></stringProp><stringProp name="parameters"></stringProp>
  <stringProp name="script"><![CDATA[long now = System.currentTimeMillis()
String startKey = 'official.benchmark.start.ms'
if (props.get(startKey) == null) {
    props.put(startKey, String.valueOf(now))
}
long startMs = Long.parseLong(String.valueOf(props.get(startKey)))
long elapsedSec = (long) ((now - startMs) / 1000L)
def windows = [
  [0L, 60L, 'DISCARD_RAMP_0000_TO_1000_RPS'],
  [60L, 70L, 'DISCARD_1000_RPS_STABILIZE_10S'],
  [70L, 130L, 'MEASURE_1000_RPS_RSAT_CONFIRM_STEADY_60S'],
  [130L, 140L, 'DISCARD_1000_RPS_END_GUARD_10S'],
  [140L, 160L, 'DISCARD_RAMP_1000_TO_1050_RPS'],
  [160L, 170L, 'DISCARD_1050_RPS_STABILIZE_10S'],
  [170L, 230L, 'MEASURE_1050_RPS_RSAT_CONFIRM_STEADY_60S'],
  [230L, 240L, 'DISCARD_1050_RPS_END_GUARD_10S'],
  [240L, 260L, 'DISCARD_RAMP_1050_TO_1100_RPS'],
  [260L, 270L, 'DISCARD_1100_RPS_STABILIZE_10S'],
  [270L, 330L, 'MEASURE_1100_RPS_RSAT_CONFIRM_STEADY_60S'],
  [330L, 340L, 'DISCARD_1100_RPS_END_GUARD_10S'],
  [340L, 360L, 'DISCARD_RAMP_1100_TO_1150_RPS'],
  [360L, 370L, 'DISCARD_1150_RPS_STABILIZE_10S'],
  [370L, 430L, 'MEASURE_1150_RPS_RSAT_CONFIRM_STEADY_60S'],
  [430L, 440L, 'DISCARD_1150_RPS_END_GUARD_10S'],
  [440L, 460L, 'DISCARD_RAMP_1150_TO_1200_RPS'],
  [460L, 470L, 'DISCARD_1200_RPS_STABILIZE_10S'],
  [470L, 530L, 'MEASURE_1200_RPS_RSAT_CONFIRM_STEADY_60S'],
  [530L, 540L, 'DISCARD_1200_RPS_END_GUARD_10S'],
  [540L, 560L, 'DISCARD_RAMP_1200_TO_1250_RPS'],
  [560L, 570L, 'DISCARD_1250_RPS_STABILIZE_10S'],
  [570L, 630L, 'MEASURE_1250_RPS_RSAT_CONFIRM_STEADY_60S'],
  [630L, 640L, 'DISCARD_1250_RPS_END_GUARD_10S'],
  [640L, 680L, 'DISCARD_RAMPDOWN_1250_TO_0000_RPS'],
]
String label = 'DISCARD_OUTSIDE_DEFINED_WINDOWS'
for (def w : windows) {
    if (elapsedSec >= (long) w[0] && elapsedSec < (long) w[1]) {
        label = (String) w[2]
        break
    }
}
vars.put('BENCHMARK_LABEL', label)
props.put('official.benchmark.current.label', label)
vars.put('ELAPSED_SECONDS', String.valueOf(elapsedSec))]]></stringProp>
  <stringProp name="scriptLanguage">groovy</stringProp>
</JSR223PreProcessor><hashTree/>

  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="[HIGH DEGRADATION] Mixed 900 RPS - Dependency Slowdown on one backend" enabled="true">
      <stringProp name="TestPlan.comments">High load at 900 RPS (~82% of R_sat=1100). Chaos target defaults to 8083. Degradation phase uses /api/chaos/dependency-slowdown/high from t=120s to t=300s.</stringProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">
          <elementProp name="GATEWAY_HOST" elementType="Argument"><stringProp name="Argument.name">GATEWAY_HOST</stringProp><stringProp name="Argument.value">172.30.35.37</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
